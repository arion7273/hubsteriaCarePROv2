VITE_APP_NAME=HubsteriaCarePRO
VITE_APP_ENV=production
VITE_APP_SUPPORT_EMAIL=support@example.com
VITE_APP_PRIVACY_CONTACT=privacy@example.com
VITE_APP_STATUS_PAGE_URL=https://status.example.com
VITE_API_BASE_URL=http://localhost:3000
VITE_ERROR_TRACKING_DSN=

PORT=3000
BACKEND_REPOSITORY_MODE=memory
DATABASE_URL=
TEST_DATABASE_URL=
RUN_POSTGRES_INTEGRATION=false
DATABASE_SSL=false
# Use BACKEND_REPOSITORY_MODE=postgres and DATABASE_URL for npm run db:migrate.
# Set RUN_POSTGRES_INTEGRATION=true and TEST_DATABASE_URL to run npm run test:postgres.
# Local development only. Deployable runtimes reject demo auth unless ALLOW_DEMO_AUTH=true and NODE_ENV is not production.
ALLOW_DEMO_AUTH=false
DEMO_AUTH_PASSWORD=
DEMO_MFA_CODE=
MFA_TOTP_SECRETS_JSON={}
SECURE_COOKIES=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
MAX_REQUEST_BODY_BYTES=1000000
AUTH_RATE_LIMIT=10
MONITORING_ENDPOINT=
ERROR_TRACKING_DSN=
RELEASE_VERSION=local-dev
ROLE_ID_T1=
ROLE_ID_T2=
ROLE_ID_T2_5=
ROLE_ID_T3=
ROLE_ID_EMPLOYEE=
ROLE_ID_FAMILY=
ROLE_ID_RESIDENT=
